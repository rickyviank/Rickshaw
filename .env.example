# Provider selection
RICKSHAW_PROVIDER=openai

# Default effort level: low, medium, high
RICKSHAW_EFFORT=medium

# OpenAI
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Devin
# DEVIN_API_KEY=...
# DEVIN_BASE_URL=https://api.devin.ai

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Local providers (llamacpp / mlx / ollama / lmstudio) — keyless by default
# LLAMACPP_BASE_URL=http://localhost:8080/v1
# MLX_BASE_URL=http://localhost:8080/v1
# OLLAMA_BASE_URL=http://localhost:11434/v1
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LLAMACPP_API_KEY=only-if-your-server-enforces-one

# Embedding provider (independent of chat provider)
# RICKSHAW_EMBEDDING_PROVIDER=openai
